rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Tattoo images and stencils: anyone can read (for public gallery), only owner can write
    match /tattoos/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /stencils/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
